<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="privilege_social_publisher" model="res.groups.privilege">
        <field name="name">Social Publisher</field>
        <field name="sequence">10</field>
        <field name="category_id" ref="base.module_category_marketing_social_marketing"/>
    </record>

    <record id="privilege_social_approver" model="res.groups.privilege">
        <field name="name">Social Approver</field>
        <field name="sequence">20</field>
        <field name="category_id" ref="base.module_category_marketing_social_marketing"/>
    </record>

    <record id="privilege_social_admin" model="res.groups.privilege">
        <field name="name">Social Admin</field>
        <field name="sequence">30</field>
        <field name="category_id" ref="base.module_category_marketing_social_marketing"/>
    </record>

    <record id="group_social_publisher" model="res.groups">
        <field name="name">Social Publisher</field>
        <field name="privilege_id" ref="tiktok_video_uploader.privilege_social_publisher"/>
    </record>

    <record id="group_social_approver" model="res.groups">
        <field name="name">Social Approver</field>
        <field name="privilege_id" ref="tiktok_video_uploader.privilege_social_approver"/>
        <field name="implied_ids" eval="[(4, ref('tiktok_video_uploader.group_social_publisher'))]"/>
    </record>

    <record id="group_social_admin" model="res.groups">
        <field name="name">Social Admin</field>
        <field name="privilege_id" ref="tiktok_video_uploader.privilege_social_admin"/>
        <field name="implied_ids" eval="[(4, ref('tiktok_video_uploader.group_social_approver'))]"/>
        <!-- Ensure System Administrators automatically have Social Admin rights -->
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
