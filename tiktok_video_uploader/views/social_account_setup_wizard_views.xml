<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_social_account_setup_wizard_form" model="ir.ui.view">
        <field name="name">social.account.setup.wizard.form</field>
        <field name="model">social.account.setup.wizard</field>
        <field name="arch" type="xml">
            <form string="Social Credential Quick Setup">
                <sheet>
                    <group col="4">
                        <field name="provider"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="account_id" options="{'no_create': True}"/>
                    </group>

                    <separator string="Step 1 — Paste credentials"/>
                    <group>
                        <field name="accepted_formats_hint" readonly="1" nolabel="1" class="text-muted"/>
                        <field name="raw_payload" nolabel="1" placeholder='Paste JSON or key/value lines, e.g. {"app_id":"...","app_secret":"..."}'/>
                    </group>

                    <separator string="Step 2 — Review detected credentials" invisible="not has_parsed_payload"/>
                    <group col="8" invisible="not has_parsed_payload">
                        <label for="detected_total" string="Detected"/>
                        <field name="detected_total" readonly="1"/>
                        <label for="mapped_total" string="Auto-Mapped"/>
                        <field name="mapped_total" readonly="1"/>
                        <label for="unmapped_total" string="Unmapped"/>
                        <field name="unmapped_total" readonly="1"/>
                        <label for="selected_total" string="Selected to Apply"/>
                        <field name="selected_total" readonly="1"/>
                    </group>

                    <group string="Detected Credentials" invisible="not has_parsed_payload">
                        <field name="line_ids" nolabel="1">
                            <list create="0" delete="0" editable="bottom">
                                <field name="apply" string="Use"/>
                                <field name="source_key" readonly="1" string="Detected Key"/>
                                <field name="detected_value_masked" readonly="1" string="Detected Value"/>
                                <field name="target_field" string="Map To"/>
                                <field name="confidence" readonly="1"/>
                                <field name="note" readonly="1"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button name="action_parse_payload" string="Parse Payload" type="object" class="btn-secondary"/>
                    <button name="action_ignore_unmapped" string="Ignore Unmapped" type="object" class="btn-secondary" invisible="not has_parsed_payload"/>
                    <button name="action_apply_credentials" string="Apply to Account" type="object" class="btn-primary" invisible="selected_total == 0"/>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_social_account_setup_wizard" model="ir.actions.act_window">
        <field name="name">Social Quick Setup</field>
        <field name="res_model">social.account.setup.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
