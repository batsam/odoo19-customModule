<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_tiktok_video_uploader" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.tiktok.video.uploader</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="TikTok" name="tiktok_video_uploader" groups="base.group_system">
                    <block title="TikTok API">
                        <setting string="TikTok Access Token" help="OAuth access token with video publish permission">
                            <field name="tiktok_access_token" password="True"/>
                        </setting>
                        <setting string="Upload Endpoint" help="TikTok API endpoint for video upload initialization/upload">
                            <field name="tiktok_upload_endpoint"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
