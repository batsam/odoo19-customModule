<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_tiktok_video_uploader" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.tiktok.video.uploader</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Social Video" name="tiktok_video_uploader">
                    <block title="User Connections">
                        <setting string="Connected Accounts" help="Manage multiple social accounts per platform">
                            <button name="action_manage_social_accounts" type="object" string="Manage Connected Accounts" class="btn-secondary"/>
                        </setting>
                        <setting string="Quick Setup Wizard" help="Paste credentials from provider portal and auto-map fields">
                            <button name="action_open_social_quick_setup" type="object" string="Open Quick Setup" class="btn-primary"/>
                        </setting>
                        <setting string="Connect TikTok Account">
                            <button name="action_tiktok_connect" type="object" string="Link TikTok Account" class="btn-primary"/>
                        </setting>
                        <setting string="Connect Facebook/Instagram">
                            <button name="action_meta_connect" type="object" string="Link Meta Account" class="btn-primary"/>
                        </setting>
                        <setting string="Advanced Meta Overrides" help="Show separate Facebook/Instagram override fields and endpoints">
                            <field name="enable_advanced_meta_overrides"/>
                        </setting>
                    </block>

                    <block title="Developer: TikTok OAuth">
                        <setting string="TikTok Client Key">
                            <field name="tiktok_client_key"/>
                        </setting>
                        <setting string="TikTok Client Secret" help="Stored in system parameters">
                            <field name="tiktok_client_secret" password="True"/>
                        </setting>
                        <setting string="TikTok Redirect URI" help="Must match your TikTok app exactly">
                            <field name="tiktok_redirect_uri"/>
                        </setting>
                        <setting string="TikTok OAuth Scopes">
                            <field name="tiktok_scopes"/>
                        </setting>
                        <setting string="TikTok Authorize Endpoint">
                            <field name="tiktok_authorize_endpoint"/>
                        </setting>
                        <setting string="TikTok Token Endpoint">
                            <field name="tiktok_token_endpoint"/>
                        </setting>
                    </block>

                    <block title="Developer: TikTok API">
                        <setting string="TikTok Access Token" help="OAuth access token with video publish permission">
                            <field name="tiktok_access_token" password="True"/>
                        </setting>
                        <setting string="TikTok Upload Endpoint">
                            <field name="tiktok_upload_endpoint"/>
                        </setting>
                        <setting string="Max Upload Size (MB)" help="Validation limit for uploaded video binary before API calls">
                            <field name="max_video_size_mb"/>
                        </setting>
                    </block>

                    <block title="Developer: Facebook API (Advanced Override)" invisible="not enable_advanced_meta_overrides">
                        <setting string="Facebook Page ID">
                            <field name="facebook_page_id"/>
                        </setting>
                        <setting string="Facebook Access Token (Override)">
                            <field name="facebook_access_token" password="True"/>
                        </setting>
                        <setting string="Facebook Graph Endpoint">
                            <field name="facebook_graph_endpoint"/>
                        </setting>
                    </block>

                    <block title="Developer: Instagram API (Advanced Override)" invisible="not enable_advanced_meta_overrides">
                        <setting string="Instagram Business User ID">
                            <field name="instagram_user_id"/>
                        </setting>
                        <setting string="Instagram Access Token (Override)">
                            <field name="instagram_access_token" password="True"/>
                        </setting>
                        <setting string="Instagram Graph Endpoint">
                            <field name="instagram_graph_endpoint"/>
                        </setting>
                    </block>

                    <block title="Developer: Meta OAuth">
                        <setting string="Meta Access Token" help="Shared token from Meta OAuth callback">
                            <field name="meta_access_token" password="True"/>
                        </setting>
                        <setting string="Meta User ID">
                            <field name="meta_user_id"/>
                        </setting>
                        <setting string="Meta App ID">
                            <field name="meta_app_id"/>
                        </setting>
                        <setting string="Meta App Secret" help="Stored in system parameters">
                            <field name="meta_app_secret" password="True"/>
                        </setting>
                        <setting string="Meta Redirect URI" help="Must match Meta app OAuth redirect URI exactly">
                            <field name="meta_redirect_uri"/>
                        </setting>
                        <setting string="Meta OAuth Scopes">
                            <field name="meta_scopes"/>
                        </setting>
                        <setting string="Meta Authorize Endpoint">
                            <field name="meta_authorize_endpoint"/>
                        </setting>
                        <setting string="Meta Token Endpoint">
                            <field name="meta_token_endpoint"/>
                        </setting>
                        <setting string="Meta Graph Endpoint">
                            <field name="meta_graph_endpoint"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
