<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_social_video_post_tree" model="ir.ui.view">
        <field name="name">social.video.post.tree</field>
        <field name="model">social.video.post</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="platform"/>
                <field name="video_filename"/>
                <field name="state"/>
                <field name="external_id"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="view_social_video_post_form" model="ir.ui.view">
        <field name="name">social.video.post.form</field>
        <field name="model">social.video.post</field>
        <field name="arch" type="xml">
            <form string="Social Video Post">
                <header>
                    <button name="action_publish" type="object" string="Publish" class="btn-primary" invisible="state == 'uploaded'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,uploaded,failed"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="platform"/>
                        <field name="video_file" filename="video_filename"/>
                        <field name="video_filename"/>
                        <field name="video_public_url" invisible="platform != 'instagram'"/>
                        <field name="caption"/>
                        <field name="privacy_level" invisible="platform != 'tiktok'"/>
                    </group>
                    <group string="API Response">
                        <field name="external_id" readonly="1"/>
                        <field name="error_message" readonly="1"/>
                        <field name="response_body" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_social_video_post" model="ir.actions.act_window">
        <field name="name">Social Video Posts</field>
        <field name="res_model">social.video.post</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_social_video_upload" name="Social Video Posts" parent="menu_tiktok_video_root" action="action_social_video_post" sequence="5"/>
</odoo>
