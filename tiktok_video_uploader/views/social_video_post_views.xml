<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_social_video_post_tree" model="ir.ui.view">
        <field name="name">social.video.post.tree</field>
        <field name="model">social.video.post</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="company_id" optional="hide"/>
                <field name="publish_tiktok"/>
                <field name="publish_facebook"/>
                <field name="publish_instagram"/>
                <field name="video_filename"/>
                <field name="state"/>
                <field name="scheduled_datetime"/>
                <field name="next_retry_at"/>
                <field name="tiktok_external_id"/>
                <field name="facebook_external_id"/>
                <field name="instagram_external_id"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="view_social_video_post_form" model="ir.ui.view">
        <field name="name">social.video.post.form</field>
        <field name="model">social.video.post</field>
        <field name="arch" type="xml">
            <form string="Social Video Post">
                <header>
                    <button name="action_publish" type="object" string="Publish Selected Platforms" class="btn-primary" invisible="state == 'uploaded'"/>
                    <button name="action_submit_review" type="object" string="Submit for Review" class="btn-secondary" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve" class="btn-secondary" invisible="state != 'in_review'"/>
                    <button name="action_reject" type="object" string="Reject" class="btn-secondary" invisible="state != 'in_review'"/>
                    <button
                        name="action_schedule_publish"
                        type="object"
                        string="Schedule"
                        class="btn-secondary"
                        invisible="publish_mode != 'schedule' or state == 'uploaded' or state == 'dead_letter'"
                    />
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_review,approved,scheduled,uploaded,partial,failed,dead_letter"/>
                </header>
                <sheet>
                    <group string="Video Content">
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="video_file" filename="video_filename"/>
                            <field name="video_filename"/>
                            <field name="caption"/>
                            <field name="requires_approval"/>
                            <field name="publish_mode"/>
                            <field name="scheduled_datetime" invisible="publish_mode != 'schedule'"/>
                        </group>
                        <group string="Publish To">
                            <field name="publish_tiktok"/>
                            <field name="publish_facebook"/>
                            <field name="publish_instagram"/>
                            <field name="target_account_ids" widget="many2many_tags"/>
                            <field name="privacy_level" invisible="not publish_tiktok"/>
                            <field name="video_public_url" invisible="not publish_instagram"/>
                        </group>
                    </group>

                    <group string="Publish Results">
                        <group string="TikTok">
                            <field name="tiktok_external_id" readonly="1"/>
                            <field name="tiktok_error_message" readonly="1"/>
                            <field name="tiktok_response_body" readonly="1"/>
                        </group>
                        <group string="Facebook">
                            <field name="facebook_external_id" readonly="1"/>
                            <field name="facebook_error_message" readonly="1"/>
                            <field name="facebook_response_body" readonly="1"/>
                        </group>
                        <group string="Instagram">
                            <field name="instagram_external_id" readonly="1"/>
                            <field name="instagram_error_message" readonly="1"/>
                            <field name="instagram_response_body" readonly="1"/>
                        </group>
                    </group>
                    <group string="Summary">
                        <field name="external_id" readonly="1"/>
                        <field name="error_message" readonly="1"/>
                        <field name="response_body" readonly="1"/>
                        <field name="last_attempt_at" readonly="1"/>
                        <field name="attempt_count" readonly="1"/>
                        <field name="max_retry"/>
                        <field name="next_retry_at" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_social_video_post_calendar" model="ir.ui.view">
        <field name="name">social.video.post.calendar</field>
        <field name="model">social.video.post</field>
        <field name="arch" type="xml">
            <calendar string="Publishing Calendar" date_start="scheduled_datetime" color="state">
                <field name="name"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="view_social_video_post_search" model="ir.ui.view">
        <field name="name">social.video.post.search</field>
        <field name="model">social.video.post</field>
        <field name="arch" type="xml">
            <search string="Search Social Posts">
                <field name="name"/>
                <field name="state"/>
                <filter name="needs_approval" string="Needs Approval" domain="[('state', '=', 'in_review')]"/>
                <filter name="scheduled" string="Scheduled" domain="[('state', '=', 'scheduled')]"/>
                <filter name="failed" string="Failed" domain="[('state', '=', 'failed')]"/>
                <filter name="dead_letter" string="Dead Letter" domain="[('state', '=', 'dead_letter')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_social_video_post" model="ir.actions.act_window">
        <field name="name">Video Publisher</field>
        <field name="res_model">social.video.post</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="search_view_id" ref="view_social_video_post_search"/>
    </record>

    <menuitem id="menu_social_video_root" name="Social Video" sequence="50"/>
    <menuitem id="menu_social_video_upload" name="Video Publisher" parent="menu_social_video_root" action="action_social_video_post" sequence="5"/>
</odoo>
